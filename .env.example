PORT=3000

# SMTP — Resend (recommended — 100 free emails/day)
# Sign up at https://resend.com → API Keys → copy key, then:
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx  # your Resend API key
SMTP_FROM=you@yourdomain.com    # must be a verified domain in Resend
SMTP_TO=you@yourdomain.com      # where contact form notifications go

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...

# AI cost control (optional — defaults shown)
# AI_DAILY_IP_LIMIT=30          # max chat messages per IP per day
# AI_DAILY_TOKEN_LIMIT=100000   # max total tokens per day across all users
