PORT=3000

# SMTP config (works with Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com
SMTP_TO=recipient@gmail.com

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...

# AI cost control (optional — defaults shown)
# AI_DAILY_IP_LIMIT=30          # max chat messages per IP per day
# AI_DAILY_TOKEN_LIMIT=100000   # max total tokens per day across all users
